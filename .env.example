# ─────────────────────────────────────────
# UTA Backend - Environment Variables
# cp .env.example .env ve değerleri doldurun
# ─────────────────────────────────────────

# App
NODE_ENV=production
PORT=3000
APP_URL=https://api.uta.com.tr

# Database
DATABASE_URL=postgresql://uta_user:GUCLU_SIFRE@postgres:5432/uta_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=REDIS_SIFRE

# JWT
JWT_SECRET=EN_AZ_64_KARAKTER_UZUN_COK_GUCLU_RASTGELE_BIR_SECRET_BURAYA
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REFRESH_ICIN_AYRI_VE_FARKLI_BIR_SECRET_BURAYA
JWT_REFRESH_EXPIRES_IN=7d

# File Upload (MinIO veya AWS S3)
STORAGE_DRIVER=minio         # minio | s3
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio_access
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET=uta-documents

# (S3 kullanacaksan)
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=uta-documents

# Mail (Nodemailer)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=noreply@uta.com.tr
MAIL_PASS=MAIL_SIFRE
MAIL_FROM="UTA Platform <noreply@uta.com.tr>"

# Throttle (rate limiting)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS - izin verilen originler (virgülle ayır)
CORS_ORIGINS=https://uta.com.tr,https://www.uta.com.tr
